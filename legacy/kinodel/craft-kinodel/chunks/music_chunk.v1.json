      "align visual rhythm"
    ],
    "instructions": [
      "Use ALM summary and energy curve; keep audio as reference path, not inline prompt content."
    ],
    "forbidden_uses": [
      "do not clone melody",
      "do not copy copyrighted lyrics",
      "do not impersonate artist identity"
    ]
