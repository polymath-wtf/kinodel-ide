          "muse inspiration",
          "montage mood reference",
          "storyboard rhythm influence"
        ],
        "priority": "P1",
        "consumers": [
          "muse-kinodel",
          "storyboard-kinodel",
          "filmmaker-kinodel",
          "montage-kinodel"
        ]
      },
      {
        "handle": "@doc1",
        "path": "refs/lyrics.txt",
        "modality": "text",
        "role": "lyrics/transcript reference",
        "take": [
          "theme",
          "phrase density",
          "section structure"
        ],
        "ignore": [
          "copying exact lines unless user owns/permits"
        ],
        "use_cases": [
          "muse lyrics style constraints"
        ],
        "priority": "P2",
        "consumers": [
          "muse-kinodel"
        ]
      }
    ]
  },
  "action": {
    "consumer_tasks": [
